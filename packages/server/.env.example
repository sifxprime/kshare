# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# Server
PORT=4000
NODE_ENV=production

# Domain — your base domain, subdomains will be PREFIX.BASE_DOMAIN
BASE_DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Tunnel settings
TUNNEL_TTL_HOURS=24
MAX_TUNNELS_PER_IP=5
MAX_BODY_SIZE_MB=10

# Admin dashboard — internal only, never expose this publicly
# Admin panel runs on ADMIN_PORT (localhost only, not behind Nginx)
ADMIN_PORT=4001
ADMIN_SECRET=change-this-to-a-long-random-string

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200

# JWT for user dashboard login
JWT_SECRET=change-this-to-another-long-random-string
JWT_EXPIRES_IN=7d
